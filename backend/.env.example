# ══════════════════════════════════════════════════════
# JobAgent Pro — Environment Variables
# Copy this to .env and fill in your real values
# NEVER commit .env to Git
# ══════════════════════════════════════════════════════

# ── AI (Required) ──────────────────────────────────────
GROQ_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# ── Job Discovery (Required) ───────────────────────────
# Get free key at: rapidapi.com → search "JSearch" → Subscribe Free
RAPIDAPI_KEY=YOUR-RAPIDAPI-KEY-HERE

# ── WhatsApp Notifications via Twilio (Optional) ───────
# Get free sandbox at: console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your WhatsApp number with country code:
WHATSAPP_TO=whatsapp:+12025551234

# ── Server Config ──────────────────────────────────────
PORT=3001
DB_PATH=./data/jobagent.db
NODE_ENV=development

# ── Safety Config ──────────────────────────────────────
# Max jobs to process per agent run (prevents API cost overruns)
MAX_JOBS_PER_RUN=20
# Min match score to trigger tailoring + notification (0-100)
MIN_SCORE_TO_NOTIFY=60
